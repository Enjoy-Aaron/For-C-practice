# ==============================================
# 1. C++ 编译生成的文件 (核心！必须忽略)
# ==============================================
*.o
*.obj
*.exe
*.out
*.a
*.lib
*.dll
*.so
*.dylib

# 编译输出文件夹
bin/
build/
obj/
Debug/
Release/
x64/
x86/

# ==============================================
# 2. Code::Blocks 编辑器文件 (你项目里的 .cbp/.layout)
# ==============================================
*.cbp
*.layout
*.depend

# ==============================================
# 3. 通用编辑器 / IDE 配置
# ==============================================
# VS Code
.vscode/
# Visual Studio
.vs/
*.sln
*.vcxproj
*.vcxproj.filters
# CLion
.idea/
cmake-build-*/

# ==============================================
# 4. Windows 系统垃圾文件
# ==============================================
Thumbs.db
Thumbs.db:encryptable
desktop.ini
*.tmp
*.log

# ==============================================
# 5. 其他临时/无用文件
# ==============================================
.DS_Store
*.bak
*.swp